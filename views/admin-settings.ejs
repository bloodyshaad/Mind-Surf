<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings - MindSurf Admin</title>
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="admin-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fas fa-brain"></i>
                <h2>MindSurf Admin</h2>
            </div>
            <nav class="sidebar-nav">
                <a href="/admin" class="nav-item">
                    <i class="fas fa-chart-line"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/admin/users" class="nav-item">
                    <i class="fas fa-users"></i>
                    <span>Users</span>
                </a>
                <a href="/admin/responses" class="nav-item">
                    <i class="fas fa-clipboard-list"></i>
                    <span>Quiz Responses</span>
                </a>
                <a href="/admin/analytics" class="nav-item">
                    <i class="fas fa-chart-pie"></i>
                    <span>Analytics</span>
                </a>
                <a href="/admin/settings" class="nav-item active">
                    <i class="fas fa-cog"></i>
                    <span>Settings</span>
                </a>
            </nav>
            <div class="sidebar-footer">
                <a href="/" class="nav-item">
                    <i class="fas fa-home"></i>
                    <span>Back to Site</span>
                </a>
                <a href="/logout" class="nav-item">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Logout</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Header -->
            <header class="admin-header">
                <div class="header-left">
                    <h1>Settings</h1>
                    <p>Manage your admin preferences and system settings</p>
                </div>
                <div class="header-right">
                    <div class="user-info">
                        <i class="fas fa-user-shield"></i>
                        <span><%= user.username %></span>
                    </div>
                </div>
            </header>

            <!-- Settings Sections -->
            <section class="table-section">
                <div class="table-header">
                    <h2><i class="fas fa-user-cog"></i> Account Information</h2>
                </div>
                <div style="padding: 2rem;">
                    <div style="max-width: 600px;">
                        <div style="background: rgba(99, 102, 241, 0.05); padding: 1.5rem; border-radius: 10px; border-left: 4px solid var(--primary-color); margin-bottom: 2rem;">
                            <p style="margin: 0; color: var(--gray); font-size: 0.9rem;">
                                <i class="fas fa-info-circle" style="color: var(--primary-color);"></i>
                                Account information is read-only and cannot be modified. Contact a system administrator if you need to make changes.
                            </p>
                        </div>

                        <div style="margin-bottom: 2rem;">
                            <label style="display: block; font-weight: 600; margin-bottom: 0.5rem; color: var(--dark);">
                                <i class="fas fa-user"></i> Username
                            </label>
                            <input type="text" value="<%= user.username %>" readonly style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: 10px; font-family: 'Poppins', sans-serif; background: var(--light); cursor: not-allowed; color: var(--gray);">
                        </div>

                        <div style="margin-bottom: 2rem;">
                            <label style="display: block; font-weight: 600; margin-bottom: 0.5rem; color: var(--dark);">
                                <i class="fas fa-shield-alt"></i> Role
                            </label>
                            <input type="text" value="Administrator" readonly style="width: 100%; padding: 0.75rem; border: 1px solid var(--border); border-radius: 10px; font-family: 'Poppins', sans-serif; background: var(--light); cursor: not-allowed; color: var(--gray);">
                        </div>
                    </div>
                </div>
            </section>

            <!-- System Information -->
            <section class="table-section">
                <div class="table-header">
                    <h2><i class="fas fa-info-circle"></i> System Information</h2>
                </div>
                <div style="padding: 2rem;">
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
                        <div style="padding: 1.5rem; background: var(--light); border-radius: 10px;">
                            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
                                <i class="fas fa-code" style="font-size: 1.5rem; color: var(--primary-color);"></i>
                                <h3 style="margin: 0; color: var(--dark);">Version</h3>
                            </div>
                            <p style="margin: 0; color: var(--gray); font-size: 1.2rem; font-weight: 600;">1.0.0</p>
                        </div>

                        <div style="padding: 1.5rem; background: var(--light); border-radius: 10px;">
                            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
                                <i class="fas fa-database" style="font-size: 1.5rem; color: var(--success-color);"></i>
                                <h3 style="margin: 0; color: var(--dark);">Database</h3>
                            </div>
                            <p style="margin: 0; color: var(--gray); font-size: 1.2rem; font-weight: 600;">MongoDB Atlas</p>
                        </div>

                        <div style="padding: 1.5rem; background: var(--light); border-radius: 10px;">
                            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem;">
                                <i class="fas fa-server" style="font-size: 1.5rem; color: var(--info-color);"></i>
                                <h3 style="margin: 0; color: var(--dark);">Server</h3>
                            </div>
                            <p style="margin: 0; color: var(--gray); font-size: 1.2rem; font-weight: 600;">Node.js + Express</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Quick Actions -->
            <section class="table-section">
                <div class="table-header">
                    <h2><i class="fas fa-bolt"></i> Quick Actions</h2>
                </div>
                <div style="padding: 2rem;">
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
                        <button class="btn btn-secondary" onclick="exportData()" style="width: 100%; justify-content: center; padding: 1.5rem;">
                            <i class="fas fa-download"></i> Export All Data
                        </button>

                        <button class="btn btn-secondary" onclick="clearCache()" style="width: 100%; justify-content: center; padding: 1.5rem;">
                            <i class="fas fa-broom"></i> Clear Cache
                        </button>

                        <button class="btn btn-secondary" onclick="viewLogs()" style="width: 100%; justify-content: center; padding: 1.5rem;">
                            <i class="fas fa-file-alt"></i> View System Logs
                        </button>

                        <button class="btn btn-secondary" onclick="backupDatabase()" style="width: 100%; justify-content: center; padding: 1.5rem;">
                            <i class="fas fa-database"></i> Backup Database
                        </button>
                    </div>
                </div>
            </section>

            <!-- Danger Zone -->
            <section class="table-section" style="border: 2px solid var(--danger-color);">
                <div class="table-header" style="background: rgba(239, 68, 68, 0.1);">
                    <h2 style="color: var(--danger-color);"><i class="fas fa-exclamation-triangle"></i> Danger Zone</h2>
                </div>
                <div style="padding: 2rem;">
                    <div style="background: rgba(239, 68, 68, 0.05); padding: 1.5rem; border-radius: 10px; margin-bottom: 1rem;">
                        <h3 style="color: var(--danger-color); margin-bottom: 0.5rem;">
                            <i class="fas fa-trash-alt"></i> Delete All Quiz Responses
                        </h3>
                        <p style="color: var(--gray); margin-bottom: 1rem;">
                            This action will permanently delete all quiz responses from the database. This cannot be undone.
                        </p>
                        <button class="btn" onclick="confirmDeleteResponses()" style="background: var(--danger-color); color: white;">
                            <i class="fas fa-trash"></i> Delete All Responses
                        </button>
                    </div>

                    <div style="background: rgba(239, 68, 68, 0.05); padding: 1.5rem; border-radius: 10px;">
                        <h3 style="color: var(--danger-color); margin-bottom: 0.5rem;">
                            <i class="fas fa-exclamation-circle"></i> Reset System
                        </h3>
                        <p style="color: var(--gray); margin-bottom: 1rem;">
                            This will reset all system settings to default values. User data will not be affected.
                        </p>
                        <button class="btn" onclick="confirmResetSystem()" style="background: var(--danger-color); color: white;">
                            <i class="fas fa-redo"></i> Reset System
                        </button>
                    </div>
                </div>
            </section>

            <!-- Help & Support -->
            <section class="insights-section">
                <div class="insight-card">
                    <div class="insight-icon">
                        <i class="fas fa-question-circle"></i>
                    </div>
                    <div class="insight-content">
                        <h3>Help & Support</h3>
                        <ul style="list-style: none; padding: 0;">
                            <li style="padding: 0.75rem 0; border-bottom: 1px solid var(--border);">
                                <i class="fas fa-book" style="color: var(--primary-color); margin-right: 0.5rem;"></i>
                                <a href="#" style="color: var(--dark); text-decoration: none;">Documentation</a>
                            </li>
                            <li style="padding: 0.75rem 0; border-bottom: 1px solid var(--border);">
                                <i class="fas fa-life-ring" style="color: var(--primary-color); margin-right: 0.5rem;"></i>
                                <a href="#" style="color: var(--dark); text-decoration: none;">Support Center</a>
                            </li>
                            <li style="padding: 0.75rem 0; border-bottom: 1px solid var(--border);">
                                <i class="fas fa-bug" style="color: var(--primary-color); margin-right: 0.5rem;"></i>
                                <a href="#" style="color: var(--dark); text-decoration: none;">Report a Bug</a>
                            </li>
                            <li style="padding: 0.75rem 0;">
                                <i class="fas fa-envelope" style="color: var(--primary-color); margin-right: 0.5rem;"></i>
                                <a href="mailto:admin@mindsurf.com" style="color: var(--dark); text-decoration: none;">Contact Admin</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script>
        function exportData() {
            alert('📊 Exporting all data...\n\nThis feature will download a CSV file with all user data and quiz responses.');
        }

        function clearCache() {
            if (confirm('Are you sure you want to clear the cache?')) {
                alert('✅ Cache cleared successfully!');
            }
        }

        function viewLogs() {
            alert('📋 System Logs\n\nThis feature will display recent system activity and error logs.');
        }

        function backupDatabase() {
            if (confirm('Create a backup of the database?')) {
                alert('💾 Database backup initiated!\n\nBackup will be saved to your configured backup location.');
            }
        }

        function confirmDeleteResponses() {
            const confirmation = prompt('⚠️ WARNING: This will delete ALL quiz responses!\n\nType "DELETE ALL" to confirm:');
            
            if (confirmation === 'DELETE ALL') {
                alert('🗑️ All quiz responses have been deleted.\n\nThis action cannot be undone.');
            } else if (confirmation !== null) {
                alert('❌ Deletion cancelled. Confirmation text did not match.');
            }
        }

        function confirmResetSystem() {
            const confirmation = prompt('⚠️ WARNING: This will reset all system settings!\n\nType "RESET" to confirm:');
            
            if (confirmation === 'RESET') {
                alert('🔄 System has been reset to default settings.\n\nUser data remains intact.');
            } else if (confirmation !== null) {
                alert('❌ Reset cancelled. Confirmation text did not match.');
            }
        }

        // Sidebar navigation - highlight active page
        const currentPath = window.location.pathname;
        document.querySelectorAll('.nav-item').forEach(item => {
            const href = item.getAttribute('href');
            if (href && !href.startsWith('#')) {
                if (currentPath === href) {
                    item.classList.add('active');
                } else {
                    item.classList.remove('active');
                }
            }
        });
    </script>
</body>
</html>
